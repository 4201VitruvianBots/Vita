{
  "workbench.startupEditor": "none",
  "npm.autoDetect": "on",
  "typescript.tsc.autoDetect": "off",
  "markdown.preview.breaks": true,
  "workbench.editorAssociations": {
    "WELCOME.md": "vscode.markdown.preview.editor",
    "**/docs/Index.md": "vscode.markdown.preview.editor",
    "Index.md": "vscode.markdown.preview.editor"
  },
  "files.exclude": {
    "**/*.js": true,
    "**/*.json": true,
    "**/*.html": true,
    "**/*.css": true,
    "**/*.yml": true,
    "**/*.yaml": true,
    ".env*": true,
    ".nojekyll": true,
    "LICENSE": true,
    ".gitignore": true
  }
}
